  "decisions": {
    "title": "Decisiones Técnicas",
    "whyLabel": "Por qué:",
    "tradeoffLabel": "Trade-off:",
    "alternativesLabel": "Alternativas:",
    "items": [
      {
        "title": "Separación de Frontends (Homero vs Marge)",
        "why": "Homero público con cache agresivo, Marge con auth y datos sensibles",
        "tradeoff": "Duplicación de código vs. Independencia de deploy, optimización de bundle, seguridad por separación",
        "alternatives": "Single SPA with code-splitting"
      },
      {
        "title": "Supabase como Backend-as-a-Service",
        "why": "Menos infraestructura, precio predictivo, RLS incorporado",
        "tradeoff": "Vendor lock-in vs. Rápido para MVP, bajo mantenimiento inicial",
        "alternatives": "Auth0 + RDS independiente, Firebase"
      },
      {
        "title": "TSOA para Generación de API",
        "why": "Type safety end-to-end, OpenAPI automático, validación integrada",
        "tradeoff": "Menos flexible vs. Menos código repetitivo, mejor DX",
        "alternatives": "Express manual, NestJS, Fastify"
      },
      {
        "title": "Cloudflare R2 vs AWS S3",
        "why": "Costo: $0 egress fees (vs AWS), S3-compatible",
        "tradeoff": "Menos maduro vs. Ahorro significativo en costos de salida",
        "alternatives": "AWS S3, MinIO self-hosted"
      },
      {
        "title": "WhatsApp (WAHA) Self-Hosted",
        "why": "Costo cero (usa WhatsApp no oficial), control total",
        "tradeoff": "No oficial, puede romperse vs. Sin costo de licenciamiento",
        "alternatives": "Twilio, MessageBird, WATI"
      },
      {
        "title": "Microservicio de Pagos (Omnipago)",
        "why": "Separación de responsabilidades, aislamiento de fallas de pagos",
        "tradeoff": "Complejidad de deployment vs. Aislamiento de fallas, escalabilidad independiente",
        "alternatives": "Integrado en barto (monolito)"
      }
    ]
  },
