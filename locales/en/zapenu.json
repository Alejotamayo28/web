  "decisions": {
    "title": "Technical Decisions",
    "why": "Why:",
    "tradeoff": "Trade-off:",
    "alternatives": "Alternatives:",
    "items": [
      {
        "decision": "Frontend Separation (Homero vs Marge)",
        "why": "Public Homero with aggressive cache, Marge with auth and sensitive data",
        "tradeoff": "Code duplication, maintenance overhead vs. Deploy independence, bundle optimization, security by separation",
        "alternatives": "Single SPA with code-splitting"
      },
      {
        "decision": "Supabase as Backend-as-a-Service",
        "why": "Less infrastructure, predictable pricing, built-in RLS",
        "tradeoff": "Vendor lock-in, connection limits, latency in uncovered regions",
        "alternatives": "Auth0 + independent RDS, Firebase"
      },
      {
        "decision": "TSOA for API Generation",
        "why": "End-to-end type safety, automatic OpenAPI, integrated validation",
        "tradeoff": "Learning curve, less flexible than pure Express, tooling dependency",
        "alternatives": "Manual Express, NestJS, Fastify"
      },
      {
        "decision": "Cloudflare R2 vs AWS S3",
        "why": "Cost: $0 egress fees (vs AWS), S3-compatible",
        "tradeoff": "Less mature, fewer native integrations, Cloudflare dependency",
        "alternatives": "AWS S3, MinIO self-hosted"
      },
      {
        "decision": "WhatsApp (WAHA) Self-Hosted",
        "why": "Zero cost (uses unofficial WhatsApp Business API), total control",
        "tradeoff": "Unofficial, can break, requires maintaining active session",
        "alternatives": "Twilio, MessageBird, WATI"
      },
      {
        "decision": "Payment Microservice (Omnipago)",
        "why": "Separation of concerns, failure isolation for payments",
        "tradeoff": "Deployment complexity, additional latency (HTTP between services)",
        "alternatives": "Integrated in barto (monolith)"
      }
    ]
  },
