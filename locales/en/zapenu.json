  "decisions": {
    "title": "Technical Decisions",
    "whyLabel": "Why:",
    "tradeoffLabel": "Trade-off:",
    "alternativesLabel": "Alternatives:",
    "items": [
      {
        "title": "Frontend Separation (Homero vs Marge)",
        "why": "Public Homero with aggressive cache, Marge with auth and sensitive data",
        "tradeoff": "Code duplication vs. Deploy independence, bundle optimization, security by separation",
        "alternatives": "Single SPA with code-splitting"
      },
      {
        "title": "Supabase as Backend-as-a-Service",
        "why": "Less infrastructure, predictable pricing, built-in RLS",
        "tradeoff": "Vendor lock-in vs. Fast for MVP, low initial maintenance",
        "alternatives": "Auth0 + independent RDS, Firebase"
      },
      {
        "title": "TSOA for API Generation",
        "why": "End-to-end type safety, automatic OpenAPI, integrated validation",
        "tradeoff": "Less flexible vs. Less boilerplate, better DX",
        "alternatives": "Manual Express, NestJS, Fastify"
      },
      {
        "title": "Cloudflare R2 vs AWS S3",
        "why": "Cost: $0 egress fees (vs AWS), S3-compatible",
        "tradeoff": "Less mature vs. Significant savings on egress costs",
        "alternatives": "AWS S3, MinIO self-hosted"
      },
      {
        "title": "WhatsApp (WAHA) Self-Hosted",
        "why": "Zero cost (uses unofficial WhatsApp), total control",
        "tradeoff": "Unofficial, can break vs. No licensing costs",
        "alternatives": "Twilio, MessageBird, WATI"
      },
      {
        "title": "Payment Microservice (Omnipago)",
        "why": "Separation of concerns, failure isolation for payments",
        "tradeoff": "Deployment complexity vs. Failure isolation, independent scalability",
        "alternatives": "Integrated in barto (monolith)"
      }
    ]
  },
